DATABASE_URL=postgres://postgres:postgres@localhost:5432/render_platform
PORT=3001

# Secreto para firmar los JWT de sesión. Generá uno propio y fuerte, por
# ejemplo con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Nunca reutilices el de otro entorno ni lo dejes vacío.
JWT_SECRET=

# Solo se usan una vez, al correr `npm run seed:usuarios` para crear las
# cuentas iniciales (agustin, franco, augusto, luciano, german, oriana).
# No hace falta dejarlas en el .env real una vez sembrados los usuarios.
SEED_PASSWORD_DEFAULT=
