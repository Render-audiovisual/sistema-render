{
  "name": "render-platform-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:check": "node src/db-check.js",
    "migrate": "node scripts/migrate.js",
    "seed:usuarios": "node scripts/seed-usuarios.js",
    "importar:planificador": "node scripts/importar-planificador-historias.js",
    "importar:publicaciones": "node scripts/importar-publicaciones.js",
    "setup": "npm run migrate && node -e \"import('./src/setup-demo-data.js').then(m => m.setupDemoClientes()).then(() => process.exit(0))\" && npm run seed:usuarios"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3"
  }
}
